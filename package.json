{
  "name": "@vc-shell/root",
  "version": "2.0.0-alpha.33",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/VirtoCommerce/vc-shell.git"
  },
  "scripts": {
    "prepare": "husky install",
    "setup:apps": "tsx scripts/setup-app.ts",
    "dev:storybook": "storybook dev -p 6006 --no-open",
    "build": "yarn workspaces foreach -v --worktree --topological-dev --from '{@vc-shell/mf-config,@vc-shell/config-generator,@vc-shell/api-client-generator,@vc-shell/create-vc-app,@vc-shell/migrate,@vc-shell/framework,@vc-shell/mf-host,@vc-shell/mf-module}' run build",
    "build:analyze": "ANALYZE=true yarn build",
    "build:framework": "yarn workspace @vc-shell/framework run build",
    "build:cli:config": "yarn workspace @vc-shell/config-generator run build",
    "build:cli:api-client": "yarn workspace @vc-shell/api-client-generator run build",
    "build:cli:create-vc-app": "yarn workspace @vc-shell/create-vc-app run build",
    "build:storybook": "cross-env APP_ENV=production shx rm -rf storybook-static && storybook build",
    "build:storybook:compress": "vite-node --mode production scripts/compress-storybook.ts --",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest --config framework/vitest.config.ts run",
    "test:storybook": "vitest --project=storybook run",
    "test:coverage": "vitest --config framework/vitest.config.ts run --coverage",
    "test:snapshot:update": "vitest --project=storybook run -u",
    "lint": "eslint --fix --cache 'framework/**/*.{ts,vue}' 'cli/**/*.{ts,vue}' 'configs/**/*.{ts,vue}' 'packages/**/*.{ts,vue}'",
    "lint:check": "eslint --cache 'framework/**/*.{ts,vue}' 'cli/**/*.{ts,vue}' 'configs/**/*.{ts,vue}' 'packages/**/*.{ts,vue}' --max-warnings=0",
    "format": "prettier --write 'framework/**/*.{ts,vue,json,md,css,scss}' 'cli/**/*.{ts,vue,json,md}' 'configs/**/*.{ts,vue,json,md}' 'packages/**/*.{ts,vue,json,md}'",
    "format:check": "prettier --check 'framework/**/*.{ts,vue,json,md,css,scss}' 'cli/**/*.{ts,vue,json,md}' 'configs/**/*.{ts,vue,json,md}' 'packages/**/*.{ts,vue,json,md}'",
    "stylelint": "stylelint --fix 'framework/**/*.{vue,css,scss}'",
    "stylelint:check": "stylelint 'framework/**/*.{vue,css,scss}'",
    "typecheck": "yarn workspace @vc-shell/framework run check:types",
    "check": "yarn lint:check && yarn format:check && yarn stylelint:check && yarn typecheck && yarn check:locales && yarn check:circular && yarn check:layers",
    "check:locales": "tsx framework/scripts/check-locales.mts",
    "check:circular": "madge --circular framework/",
    "check:layers": "tsx scripts/check-layer-violations.ts",
    "generate:api-client": "yarn workspace @vc-shell/framework exec cross-env api-client-generator --APP_PLATFORM_MODULES='[VirtoCommerce.Platform]' --APP_API_CLIENT_DIRECTORY=./core/api/ --SKIP_BUILD=true --APP_TYPE_STYLE=Interface",
    "generate:changelogs": "tsx scripts/generate-initial-changelogs.ts",
    "release:dry": "tsx scripts/release-preflight.ts && release-it --dry-run",
    "publish:packages": "yarn workspaces foreach -v --worktree --no-private --from '{@vc-shell/framework,@vc-shell/api-client-generator,@vc-shell/create-vc-app,@vc-shell/config-generator,@vc-shell/migrate,@vc-shell/ts-config,@vc-shell/mf-config,@vc-shell/mf-host,@vc-shell/mf-module,@vc-shell/vc-app-skill}' npm publish --access public",
    "changed": "LAST_TAG=$(git describe --tags --abbrev=0 --match 'v*' 2>/dev/null) && git log --oneline \"${LAST_TAG}\"..HEAD || git log --oneline",
    "diff": "LAST_TAG=$(git describe --tags --abbrev=0 --match 'v*' 2>/dev/null) && git diff --stat \"${LAST_TAG}\"..HEAD || git diff --stat",
    "clean": "find . -name node_modules -type d -prune -exec rm -rf {} + && find . -name dist -type d -prune -exec rm -rf {} +",
    "lint-staged": "lint-staged",
    "pre-commit": "yarn lint-staged && yarn check:locales && yarn check:layers"
  },
  "workspaces": [
    "apps/*",
    "framework",
    "cli/*",
    "configs/*",
    "packages/*"
  ],
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@rollup/plugin-typescript": "^11.1.5",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-links": "10.2.10",
    "@storybook/addon-onboarding": "10.2.10",
    "@storybook/addon-vitest": "10.2.10",
    "@storybook/vue3": "10.2.10",
    "@storybook/vue3-vite": "10.2.10",
    "@types/adm-zip": "^0.5.5",
    "@types/conventional-changelog": "^6.0.1",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/jquery": "^3.5.32",
    "@types/jscodeshift": "^17.3.0",
    "@types/lodash": "^4.17.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/browser": "^3.1.2",
    "@vitest/coverage-v8": "^3.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "adm-zip": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "chalk": "^5.3.0",
    "conventional-changelog": "^5.1.0",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.35.0",
    "eslint-define-config": "^2.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-storybook": "10.2.10",
    "eslint-plugin-vue": "^10.4.0",
    "globby": "^13.2.2",
    "husky": "^8.0.0",
    "jest-image-snapshot": "^6.5.2",
    "jquery": "^3.7.1",
    "lightningcss": "^1.30.1",
    "lint-staged": "^15.2.2",
    "lodash-es": "^4.17.21",
    "madge": "^8.0.0",
    "path": "^0.12.7",
    "playwright": "^1.52.0",
    "postcss": "^8.4.38",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "puppeteer": "^24.36.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "release-it": "^19.2.4",
    "sass": "^1.87.0",
    "shx": "^0.3.4",
    "storybook": "10.2.10",
    "storybook-vue3-router": "^7.0.0",
    "stylelint": "^17.6.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-node": "^3.1.3",
    "vite-plugin-checker": "^0.9.1",
    "vite-plugin-mkcert": "^1.17.1",
    "vitest": "^3.1.2",
    "vue": "^3.5.30",
    "vue-component-meta": "^3.2.5",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "cross-spawn": "^7.0.3",
    "semver": "^7.7.4"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix --cache --max-warnings=0",
      "prettier --write"
    ],
    "*.{vue,css,scss}": [
      "stylelint --fix"
    ],
    "*.{html,css,json,md}": [
      "prettier --write"
    ]
  },
  "resolutions": {
    "@module-federation/dts-plugin": "2.0.1",
    "undici": "^6.24.0"
  },
  "packageManager": "yarn@4.9.2"
}
