<div
  data-v-app=""
>
  <div
    class="tw-min-h-[340px] tw-rounded-xl tw-border tw-border-solid tw-border-neutrals-200 tw-bg-additional-50 tw-p-6"
  >
    <p
      class="tw-mb-1 tw-text-sm tw-text-neutrals-500"
    >
      Long list + keyboard navigation
    </p>
    <p
      class="tw-mb-5 tw-text-sm tw-text-neutrals-700"
    >
      Use Arrow keys, Enter and Escape.
    </p>
    <div
      class="vc-dropdown"
    >
      <div
        aria-controls="vc-dropdown-2020"
        aria-expanded="true"
        aria-haspopup="listbox"
        class="vc-dropdown__trigger"
        role="button"
        tabindex="0"
      >
        
        <button
          class="vc-button vc-button-ghost vc-button--default"
          type="button"
        >
          <!-- Loading: spinner replaces icon; shown inline next to text -->
          <!--v-if-->
          <span
            class="vc-button__title"
          >
            
            <span
              class="tw-flex tw-items-center tw-gap-2"
            >
              <svg
                aria-hidden="true"
                class="lucide vc-lucide-icon vc-lucide-icon--m vc-icon vc-icon--m lucide-list-filter-icon lucide-list-filter vc-lucide-icon vc-lucide-icon--m vc-icon vc-icon--m"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M2 5h20"
                />
                <path
                  d="M6 12h12"
                />
                <path
                  d="M9 19h6"
                />
              </svg>
               Audience segments 
              <svg
                aria-hidden="true"
                class="lucide vc-lucide-icon vc-lucide-icon--m vc-icon vc-icon--m lucide-chevron-up-icon lucide-chevron-up vc-lucide-icon vc-lucide-icon--m vc-icon vc-icon--m"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m18 15-6-6-6 6"
                />
              </svg>
            </span>
            
          </span>
        </button>
        
      </div>
