{
  "name": "@vc-shell/mf-host",
  "description": "Module Federation host runtime for VC Shell — discovers and loads remote modules",
  "version": "2.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-helper.d.ts",
      "import": "./dist/vite-helper.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b --clean && tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@module-federation/runtime": "^2.1.0",
    "@vc-shell/mf-config": "workspace:*",
    "semver": "^7.6.2"
  },
  "peerDependencies": {
    "@vc-shell/framework": "^2.0.3",
    "@vueuse/core": "^10.0.0",
    "lodash-es": "^4.0.0",
    "vee-validate": "^4.12.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.0.0 || ^11.0.0",
    "vue-router": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/semver": "^7.5.0",
    "@vc-shell/framework": "workspace:*",
    "@vc-shell/ts-config": "workspace:*",
    "@vueuse/core": "^10.7.1",
    "lodash-es": "^4.17.21",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.8.3",
    "vee-validate": "^4.12.4",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
