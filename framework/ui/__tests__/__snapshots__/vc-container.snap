<div
  data-v-app=""
>
  <div
    style="width: 400px; height: 400px; border: 1px solid rgb(204, 204, 204); border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
  >
    <div
      style="background-color: rgb(245, 245, 245); padding: 16px; border-bottom: 1px solid rgb(224, 224, 224);"
    >
      <h2
        style="margin: 0px; font-size: 1.2rem;"
      >
        Content Panel
      </h2>
    </div>
    <div
      class="vc-container"
    >
      <div
        class="vc-container__inner"
      >
        
        <h3>
          Section heading
        </h3>
        <p>
          VcContainer is often used to create scrollable panels within a larger layout.
        </p>
        <div
          style="background-color: rgb(249, 249, 249); border: 1px solid rgb(224, 224, 224); border-radius: 4px; padding: 12px; margin: 16px 0px;"
        >
          <p
            style="margin: 0px;"
          >
            <strong>
              Note:
            </strong>
             This component handles overflow automatically.
          </p>
        </div>
        <h3>
          Another section
        </h3>
        <p>
          You can include various types of content including:
        </p>
        <ul>
          <li>
            Lists like this one
          </li>
          <li>
            Images and media
          </li>
          <li>
            Form elements
          </li>
          <li>
            Other components
          </li>
        </ul>
        <p>
          The container will handle scrolling as needed.
        </p>
        <div
          style="height: 100px; background-color: rgb(224, 247, 250); display: flex; align-items: center; justify-content: center; border-radius: 4px;"
        >
           Sample content block 
        </div>
        <p
          style="margin-top: 16px;"
        >
          When content exceeds the container height, scrolling is enabled automatically.
        </p>
        
      </div>
    </div>
  </div>
</div>