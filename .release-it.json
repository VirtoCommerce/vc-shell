{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": true,
    "requireBranch": ["main", "feat/*"],
    "requireUpstream": true,
    "requireCommits": true,
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}",
    "tagAnnotation": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "header": "# Changelog",
      "preset": {
        "name": "angular"
      }
    }
  },
  "hooks": {
    "after:bump": "tsx scripts/release-hooks.ts after-bump ${version}"
  }
}
