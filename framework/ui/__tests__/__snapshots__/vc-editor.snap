      </div>
    </div>
    <div
      class="vc-editor__body"
    >
      <!-- Normal editor view -->
      <div
        class="vc-editor__content"
      >
        <div
          class="tiptap ProseMirror"
          contenteditable="true"
          role="textbox"
          tabindex="0"
          translate="no"
