    role="alert"
  >
    <svg
      aria-hidden="true"
      class="lucide vc-lucide-icon vc-lucide-icon--l vc-lucide-icon--danger vc-icon vc-icon--l vc-icon--danger vc-banner__icon vc-banner__icon lucide-circle-alert-icon lucide-circle-alert vc-lucide-icon vc-lucide-icon--l vc-lucide-icon--danger vc-icon vc-icon--l vc-icon--danger vc-banner__icon vc-banner__icon"
