<div
  data-v-app=""
>
  <div
    aria-label="Editor with custom TipTap extensions"
    class="vc-editor"
  >
    <div
      class="vc-label vc-editor__label"
    >
      <div
        class="vc-label__text"
      >
        <span
          class="vc-label__content"
        >
          
          <span>
            Editor with custom TipTap extensions
          </span>
          
        </span>
        <!--v-if-->
      </div>
      <!--v-if-->
      <!--v-if-->
    </div>
    <div
      class="vc-editor__header"
    >
      <div
        aria-label="Text formatting"
        class="vc-editor-toolbar"
        role="toolbar"
      >
        <!-- Render buttons based on toolbar prop -->
        
        
        <!-- Separator -->
        
        <!-- Bold -->
        <button
          aria-label="Bold"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-bold-icon lucide-bold vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M6 12h9a4 4 0 0 1 0 8H7a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h7a4 4 0 0 1 0 8"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Italic -->
        <button
          aria-label="Italic"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-italic-icon lucide-italic vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <line
              x1="19"
              x2="10"
              y1="4"
              y2="4"
            />
            <line
              x1="14"
              x2="5"
              y1="20"
              y2="20"
            />
            <line
              x1="15"
              x2="9"
              y1="4"
              y2="20"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Underline -->
        <button
          aria-label="Underline"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-underline-icon lucide-underline vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M6 4v6a6 6 0 0 0 12 0V4"
            />
            <line
              x1="4"
              x2="20"
              y1="20"
              y2="20"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Strikethrough -->
        <button
          aria-label="Strikethrough"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-strikethrough-icon lucide-strikethrough vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M16 4H9a3 3 0 0 0-2.83 4"
            />
            <path
              d="M14 12a4 4 0 0 1 0 8H6"
            />
            <line
              x1="4"
              x2="20"
              y1="12"
              y2="12"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        <div
          class="vc-editor-toolbar__separator"
        />
        
        
        <!-- Separator -->
        
        <!-- Heading 1 -->
        <button
          aria-label="Heading 1"
          aria-pressed="true"
          class="vc-editor-button vc-editor-button--active"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-heading1-icon lucide-heading-1 vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4 12h8"
            />
            <path
              d="M4 18V6"
            />
            <path
              d="M12 18V6"
            />
            <path
              d="m17 12 3-2v8"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Heading 2 -->
        <button
          aria-label="Heading 2"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-heading2-icon lucide-heading-2 vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4 12h8"
            />
            <path
              d="M4 18V6"
            />
            <path
              d="M12 18V6"
            />
            <path
              d="M21 18h-4c0-4 4-3 4-6 0-1.5-2-2.5-4-1"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Heading 3 -->
        <button
          aria-label="Heading 3"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-heading3-icon lucide-heading-3 vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
