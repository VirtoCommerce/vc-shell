          >
            <path
              d="M4 12h8"
            />
            <path
              d="M4 18V6"
            />
            <path
              d="M12 18V6"
            />
            <path
              d="M17.5 10.5c1.7-1 3.5 0 3.5 1.5a2 2 0 0 1-2 2"
            />
            <path
              d="M17 17.5c2 1.5 4 .3 4-1.5a2 2 0 0 0-2-2"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        <div
          class="vc-editor-toolbar__separator"
        />
        
        
        <!-- Separator -->
        
        <!-- Bullet List -->
        <button
          aria-label="Bullet list"
          aria-pressed="false"
          class="vc-editor-button"
          disabled=""
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-list-icon lucide-list vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 5h.01"
            />
            <path
              d="M3 12h.01"
            />
            <path
              d="M3 19h.01"
            />
            <path
              d="M8 5h13"
            />
            <path
              d="M8 12h13"
            />
            <path
              d="M8 19h13"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Ordered List -->
        <button
          aria-label="Numbered list"
          aria-pressed="false"
          class="vc-editor-button"
          disabled=""
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-list-ordered-icon lucide-list-ordered vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M11 5h10"
            />
            <path
              d="M11 12h10"
            />
            <path
              d="M11 19h10"
            />
            <path
              d="M4 4h1v5"
            />
            <path
              d="M4 9h2"
            />
            <path
              d="M6.5 20H3.4c0-1 2.6-1.925 2.6-3.5a1.5 1.5 0 0 0-2.6-1.02"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Blockquote -->
        <button
          aria-label="Blockquote"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-quote-icon lucide-quote vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"
            />
            <path
              d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        <div
          class="vc-editor-toolbar__separator"
        />
        
        
        <!-- Separator -->
        
        <!-- Link -->
        <button
          aria-label="Insert link"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-link-icon lucide-link vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
            />
            <path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Image -->
        <button
          aria-label="Insert image"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-image-icon lucide-image vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect
              height="18"
              rx="2"
              ry="2"
              width="18"
              x="3"
              y="3"
            />
            <circle
              cx="9"
              cy="9"
              r="2"
            />
            <path
              d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Table -->
        <button
          aria-label="Insert table"
          aria-pressed="false"
          class="vc-editor-button"
          type="button"
        >
          <svg
            aria-hidden="true"
            class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-table-icon lucide-table vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
