        </button>
      </div>
    </div>
    <div
      class="vc-editor__body"
    >
      <!-- Normal editor view -->
      <div
        class="vc-editor__content"
      >
        <div
          class="tiptap ProseMirror"
          contenteditable="true"
          role="textbox"
          tabindex="0"
          translate="no"
        >
          <p
            class="is-empty is-editor-empty"
            data-placeholder="Start typing here..."
          >
            <br
              class="ProseMirror-trailingBreak"
            />
          </p>
        </div>
      </div>
      <!-- Full preview view -->
      <!--v-if-->
      <!-- Source code view -->
      <!--v-if-->
      <!-- Side-by-side view: Editor left, Code right -->
      <!--v-if-->
    </div>
    <!-- Character count display -->
    <!--v-if-->
    <input
      accept="image/*"
      hidden=""
      multiple=""
      type="file"
    />
    <!--v-if-->
  </div>
</div>