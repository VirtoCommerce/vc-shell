{
  "name": "@vc-shell/mf-module",
  "description": "Module Federation build config for VC Shell remote modules",
  "version": "2.0.0-alpha.24",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b --clean && tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@module-federation/vite": "^1.12.2",
    "@vc-shell/mf-config": "workspace:*"
  },
  "devDependencies": {
    "@vc-shell/ts-config": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.3",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.30"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
