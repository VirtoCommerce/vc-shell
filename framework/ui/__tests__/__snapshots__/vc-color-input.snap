<div
  data-v-app=""
>
  <div
    class="tw-max-w-lg"
  >
    <div
      class="vc-color-input"
    >
      <!-- Label -->
      <label
        class="vc-label vc-color-input__label"
        for="vc-field-v-0"
        id="vc-field-v-0-label"
      >
        <div
          class="vc-label__text"
        >
          <span
            class="vc-label__content"
          >
            
            <span>
              Brand color
            </span>
            
          </span>
          <!--v-if-->
        </div>
        <!--v-if-->
        <!--v-if-->
      </label>
      <div
        class="vc-color-input__field-wrapper vc-color-input__field-wrapper--default"
      >
        <div
          class="vc-color-input__field-container"
        >
          <div
            class="vc-color-input__field"
          >
            <input
              aria-labelledby="vc-field-v-0-label"
              class="vc-color-input__input"
              id="vc-field-v-0"
              name="Field"
              placeholder="Enter hex color..."
              tabindex="0"
              type="text"
            />
            <!-- Color picker swatch -->
            <div
              class="vc-color-input__color-container"
            >
              <button
                aria-label="Pick color: #3b82f6"
                class="vc-color-input__color-square"
                style="background-color: rgb(59, 130, 246);"
                type="button"
              >
                <!-- Hidden native color input -->
                <input
                  aria-hidden="true"
                  class="vc-color-input__color-picker-hidden"
                  tabindex="-1"
                  type="color"
                  value="#3b82f6"
                />
              </button>
            </div>
            <!--v-if-->
          </div>
          <!--v-if-->
        </div>
      </div>
      <div>
        <!--v-if-->
      </div>
    </div>
    <div
      class="tw-mt-4 tw-p-2 tw-bg-gray-100 tw-rounded tw-text-sm"
    >
      <strong>
        Value:
      </strong>
       "#3b82f6" 
    </div>
  </div>
</div>-0-error"
          role="alert"
        >
          
          Please enter a valid hex color
          
        </div>
      </div>
    </div>
  </div>
</div>ke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M18 6 6 18"
                />
                <path
                  d="m6 6 12 12"
                />
              </svg>
            </button>
          </div>
          <!--v-if-->
        </div>
      </div>
      <div>
        <!--v-if-->
      </div>
    </div>
  </div>
</div>