{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": true,
    "requireBranch": ["main"],
    "requireUpstream": true,
    "requireCommits": true,
    "tagName": "v${version}",
    "commitMessage": "release: v${version}",
    "tagAnnotation": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "header": "# Changelog",
      "preset": {
        "name": "angular"
      }
    }
  },
  "hooks": {
    "after:bump": "tsx scripts/release-hooks.ts after-bump ${version} && yarn install",
    "before:stage": "git add cli/ configs/ packages/ framework/package.json apps/ CHANGELOG.md yarn.lock"
  }
}
