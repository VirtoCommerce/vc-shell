{
  "name": "@vc-shell/framework",
  "version": "2.0.0-alpha.18",
  "type": "module",
  "main": "./dist/framework.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "dist/locales/*.json",
    "globals.d.ts",
    "globals-augments.d.ts",
    "shims-vue.d.ts",
    "typings/blade-macros.d.ts",
    "tailwind.config.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/framework.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ai-agent": {
      "types": "./dist/core/plugins/ai-agent/public.d.ts",
      "import": "./dist/ai-agent/index.js"
    },
    "./extensions": {
      "types": "./dist/core/plugins/extension-points/public.d.ts",
      "import": "./dist/extensions/index.js"
    },
    "./globals": {
      "types": "./globals.d.ts"
    },
    "./package.json": "./package.json",
    "./dist/index.css": "./dist/index.css",
    "./dist/locales/*": "./dist/locales/*",
    "./tailwind.config": "./tailwind.config.ts"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.vue"
  ],
  "scripts": {
    "build": "shx rm -rf ./dist && tsx scripts/build.mts",
    "build:lib": "vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist && tsc-alias -p tsconfig.json --outDir dist",
    "type-check": "vue-tsc --noEmit",
    "check-locales": "tsx scripts/check-locales.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@floating-ui/vue": "^1.0.6",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.1.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@headlessui/vue": "^1.7.19",
    "@material-symbols/font-300": "^0.32.0",
    "@microsoft/signalr": "^8.0.0",
    "@tiptap/core": "^3.4.2",
    "@tiptap/extension-font-size": "^3.0.0-next.3",
    "@tiptap/extension-image": "^3.4.2",
    "@tiptap/extension-link": "^3.4.2",
    "@tiptap/extension-placeholder": "^3.4.2",
    "@tiptap/extension-table": "^3.4.2",
    "@tiptap/extension-table-cell": "^3.4.2",
    "@tiptap/extension-table-header": "^3.4.2",
    "@tiptap/extension-table-row": "^3.4.2",
    "@tiptap/extension-text-style": "^3.4.2",
    "@tiptap/extension-underline": "^3.4.2",
    "@tiptap/extensions": "^3.4.2",
    "@tiptap/pm": "^3.4.2",
    "@tiptap/starter-kit": "^3.4.2",
    "@tiptap/vue-3": "^3.4.2",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vee-validate/i18n": "^4.12.4",
    "@vee-validate/rules": "^4.12.4",
    "@vuepic/vue-datepicker": "^11.0.2",
    "@vueuse/components": "^10.7.1",
    "@vueuse/core": "^10.7.1",
    "@vueuse/integrations": "^10.7.1",
    "bootstrap-icons": "^1.11.3",
    "core-js": "^3.35.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.0.11",
    "gridstack": "^12.4.2",
    "iso-639-1": "^3.1.0",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.577.0",
    "normalize.css": "^8.0.1",
    "semver": "^7.7.4",
    "swiper": "^11.2.10",
    "tiptap-markdown": "^0.9.0",
    "truncate-html": "^1.1.1",
    "vee-validate": "^4.12.4",
    "vue-currency-input": "^3.0.5",
    "vue-i18n": "^11.1.11",
    "vue3-application-insights": "^1.1.0",
    "vue3-touch-events": "^4.1.8",
    "web-vitals": "^5.1.0",
    "whatwg-fetch": "^3.6.19"
  },
  "peerDependencies": {
    "vue": ">=3.4.0",
    "vue-router": ">=4.2.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "vue-router": {
      "optional": false
    }
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@laynezh/vite-plugin-lib-assets": "v1.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/semver": "^7.7.1",
    "@vc-shell/api-client-generator": "workspace:*",
    "@vc-shell/config-generator": "workspace:*",
    "@vc-shell/ts-config": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.5",
    "cypress-signalr-mock": "^1.5.0",
    "esbuild": "^0.25.3",
    "postcss": "^8.4.32",
    "sass": "^1.87.0",
    "shx": "^0.3.4",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.0.0",
    "vue-component-type-helpers": "^3.2.5",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
