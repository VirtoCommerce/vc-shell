<div
  data-v-app=""
>
  <div
    class="tw-border tw-rounded-lg tw-overflow-hidden tw-w-[500px]"
  >
    <!-- Header skeleton -->
    <div
      class="tw-flex tw-items-center tw-gap-3 tw-px-6 tw-py-4 tw-border-b"
    >
      
      <!-- Text variant: rows of skeleton lines (original behavior) -->
      
      <!-- Circle / Block variant: single shape element -->
      <div
        aria-busy="true"
        aria-label="Loading..."
        class="vc-skeleton__shape vc-skeleton__shape--circle tw-animate-pulse"
        role="status"
        style="width: 24px; height: 24px;"
      >
        <span
          class="tw-sr-only"
        >
          Loading...
        </span>
      </div>
      
      
      <div
        class="tw-flex-1 tw-flex tw-flex-col tw-gap-1"
      >
        
        <!-- Text variant: rows of skeleton lines (original behavior) -->
        
        <!-- Circle / Block variant: single shape element -->
        <div
          aria-busy="true"
          aria-label="Loading..."
          class="vc-skeleton__shape vc-skeleton__shape--block tw-animate-pulse"
          role="status"
          style="width: 40%; height: 16px;"
        >
          <span
            class="tw-sr-only"
          >
            Loading...
          </span>
        </div>
        
        
        
        <!-- Text variant: rows of skeleton lines (original behavior) -->
        
        <!-- Circle / Block variant: single shape element -->
        <div
          aria-busy="true"
          aria-label="Loading..."
          class="vc-skeleton__shape vc-skeleton__shape--block tw-animate-pulse"
          role="status"
          style="width: 25%; height: 12px;"
        >
          <span
            class="tw-sr-only"
          >
            Loading...
          </span>
        </div>
        
        
      </div>
    </div>
    <!-- Toolbar skeleton -->
    <div
      class="tw-flex tw-items-center tw-gap-3 tw-px-4 tw-py-3 tw-border-b tw-bg-[--neutrals-50]"
    >
      
      <!-- Text variant: rows of skeleton lines (original behavior) -->
      
      <!-- Circle / Block variant: single shape element -->
      <div
        aria-busy="true"
        aria-label="Loading..."
        class="vc-skeleton__shape vc-skeleton__shape--block tw-animate-pulse"
        role="status"
        style="width: 60px; height: 32px;"
      >
        <span
          class="tw-sr-only"
        >
          Loading...
        </span>
      </div>
      
      
      
      <!-- Text variant: rows of skeleton lines (original behavior) -->
      
      <!-- Circle / Block variant: single shape element -->
      <div
        aria-busy="true"
        aria-label="Loading..."
        class="vc-skeleton__shape vc-skeleton__shape--block tw-animate-pulse"
        role="status"
        style="width: 60px; height: 32px;"
      >
        <span
          class="tw-sr-only"
        >
          Loading...
        </span>
      </div>
      
      
      
      <!-- Text variant: rows of skeleton lines (original behavior) -->
      
      <!-- Circle / Block variant: single shape element -->
      <div
        aria-busy="true"
        aria-label="Loading..."
        class="vc-skeleton__shape vc-skeleton__shape--block tw-animate-pulse"
        role="status"
        style="width: 60px; height: 32px;"
      >
        <span
          class="tw-sr-only"
        >
          Loading...
        </span>
      </div>
      
      
    </div>
    <!-- Content skeleton -->
    <div
      class="tw-p-6"
    >
      
      <!-- Text variant: rows of skeleton lines (original behavior) -->
      <div
        aria-busy="true"
        aria-label="Loading..."
        class="vc-skeleton vc-skeleton--animated"
        role="status"
      >
        <span
          class="tw-sr-only"
        >
          Loading...
        </span>
        
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 100%;"
        />
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 100%;"
        />
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 100%;"
        />
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 100%;"
        />
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 100%;"
        />
        <div
          aria-hidden="true"
          class="vc-skeleton__row"
          style="width: 60%;"
        />
        
      </div>
      
    </div>
  </div>
</div>