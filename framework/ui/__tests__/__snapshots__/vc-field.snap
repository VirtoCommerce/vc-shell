<div
  data-v-app=""
>
  <div
    class="vc-field vc-field--horizontal"
  >
    <div
      class="vc-col"
      style="flex-grow: 1;"
    >
      
      <!-- Field label -->
      <div
        class="vc-label"
      >
        <div
          class="vc-label__text"
        >
          <span
            class="vc-label__content"
          >
            
            <span>
              Field Label
            </span>
            
          </span>
          <!--v-if-->
        </div>
        <span
          class="vc-label__tooltip"
        >
          <div
            class="vc-tooltip"
          >
            <div
              class="vc-tooltip__trigger"
            >
              
              <svg
                aria-hidden="true"
                class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s vc-label__tooltip-icon vc-label__tooltip-icon lucide-info-icon lucide-info vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s vc-label__tooltip-icon vc-label__tooltip-icon"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle
                  cx="12"
                  cy="12"
                  r="10"
                />
                <path
                  d="M12 16v-4"
                />
                <path
                  d="M12 8h.01"
                />
              </svg>
              
            </div>
            <!--teleport start-->
            <!--teleport end-->
          </div>
        </span>
        <!--v-if-->
      </div>
      
    </div>
    <div
      class="vc-col"
      style="flex-grow: 2;"
    >
      
      
      <!-- Text -->
      <div
        class="vc-field-type"
      >
        <div
          class="vc-field-type__text-wrap"
        >
          <p
            class="vc-field-type__text"
          >
            Field Value
          </p>
        </div>
      </div>
      <!-- Date -->
      <!--v-if-->
      <!-- Date ago -->
      <!--v-if-->
      <!-- Link -->
      <!--v-if-->
      <!-- Email -->
      <!--v-if-->
      
      
    </div>
  </div>
</div>v>
</div>      
        
      </div>
      
      
    </div>
  </div>
</div>icon-size="m"
          text=""
        />
        
      </div>
      <!-- Email -->
      <!--v-if-->
      
      
    </div>
  </div>
</div>