<div
  data-v-app=""
>
  <div
    style="display: flex; flex-direction: column; gap: 16px;"
  >
    <div
      class="vc-button-group vc-button-group--horizontal"
      role="group"
    >
      
      <button
        class="vc-button vc-button-primary vc-button--sm"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          SM via group
          
        </span>
      </button>
      <button
        class="vc-button vc-button-secondary vc-button--sm"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          SM via group
          
        </span>
      </button>
      
    </div>
    <div
      class="vc-button-group vc-button-group--horizontal"
      role="group"
    >
      
      <button
        class="vc-button vc-button-primary vc-button--default"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          Default via group
          
        </span>
      </button>
      <button
        class="vc-button vc-button-secondary vc-button--default"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          Default via group
          
        </span>
      </button>
      
    </div>
    <div
      class="vc-button-group vc-button-group--horizontal"
      role="group"
    >
      
      <button
        class="vc-button vc-button-primary vc-button--lg"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          LG via group
          
        </span>
      </button>
      <button
        class="vc-button vc-button-secondary vc-button--lg"
        type="button"
      >
        <!-- Loading: spinner replaces icon; shown inline next to text -->
        <!--v-if-->
        <span
          class="vc-button__title"
        >
          
          LG via group
          
        </span>
      </button>
      
    </div>
  </div>
</div>