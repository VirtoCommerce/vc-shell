            <path
              d="M12 3v18"
            />
            <rect
              height="18"
              rx="2"
              width="18"
              x="3"
              y="3"
            />
            <path
              d="M3 9h18"
            />
            <path
              d="M3 15h18"
            />
          </svg>
        </button>
        
        
        
        <!-- Separator -->
        
        <!-- Font Selector -->
        <div
          class="vc-editor-font-selector"
        >
          <!-- Font Size Dropdown -->
          <div
            class="vc-editor-font-selector__dropdown"
          >
            <button
              class="vc-editor-font-selector__button"
              type="button"
            >
              <svg
                aria-hidden="true"
                class="lucide vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s lucide-alarge-small-icon lucide-a-large-small vc-lucide-icon vc-lucide-icon--s vc-icon vc-icon--s"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m15 16 2.536-7.328a1.02 1.02 1 0 1 1.928 0L22 16"
                />
                <path
                  d="M15.697 14h5.606"
                />
                <path
                  d="m2 16 4.039-9.69a.5.5 0 0 1 .923 0L11 16"
                />
                <path
                  d="M3.304 13h6.392"
                />
              </svg>
              <!--v-if-->
              <svg
                aria-hidden="true"
                class="lucide vc-lucide-icon vc-lucide-icon--xs vc-icon vc-icon--xs lucide-chevron-down-icon lucide-chevron-down vc-lucide-icon vc-lucide-icon--xs vc-icon vc-icon--xs"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="m6 9 6 6 6-6"
                />
              </svg>
            </button>
            <!--v-if-->
          </div>
        </div>
        
        
        
        <!-- Custom buttons -->
        <!--v-if-->
        <!-- Table controls (always show when table is active) -->
        <!--v-if-->
      </div>
      <div
        class="vc-editor__header-actions"
      >
        <button
          aria-label="Preview"
